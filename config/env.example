# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# scripts/env_loader.py reads ONLY from environment variables.

# ----------------------------------------------------------------------------
# Runtime mode
# ----------------------------------------------------------------------------
# Allowed values: paper, live
# Anything else (or empty) → defaults to paper.
MODE=paper

# Live execution is gated by BOTH MODE=live AND ALLOW_LIVE_EXECUTION=true.
# If MODE=live but ALLOW_LIVE_EXECUTION=false, the system performs live-readiness
# checks but does not place real orders.
ALLOW_LIVE_EXECUTION=false

# ----------------------------------------------------------------------------
# Binance API
# ----------------------------------------------------------------------------
# Use a key with TRADING permission only. NEVER enable WITHDRAWAL permission.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# True → testnet (https://testnet.binancefuture.com). Default true.
BINANCE_TESTNET=true

# Defensive checks:
BINANCE_REQUIRE_NO_WITHDRAW_PERMISSION=true
BINANCE_DEFAULT_MARGIN_MODE=ISOLATED
BINANCE_DEFAULT_LEVERAGE=3
BINANCE_MAX_LEVERAGE=5

# ----------------------------------------------------------------------------
# Wallet / risk caps (used by safety-limits + risk-engine)
# ----------------------------------------------------------------------------
MIN_WALLET_BALANCE_USDT=5
MAX_MARGIN_PER_TRADE_PERCENT=20
MAX_MARGIN_PER_TRADE_USDT=2
MAX_PLANNED_LOSS_PER_TRADE_MARGIN_PERCENT=5
DAILY_MAX_LOSS_PERCENT=15
MAX_CONSECUTIVE_LOSSES=3
MAX_OPEN_POSITIONS=2

# ----------------------------------------------------------------------------
# Telegram bot
# ----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Comma-separated list of additional chat IDs allowed to control the bot.
# (TELEGRAM_CHAT_ID is implicitly allowed.)
TELEGRAM_ALLOWED_CHAT_IDS=

# Use long polling (getUpdates) by default. Webhook needs a public HTTPS URL.
TELEGRAM_ENABLE_LONG_POLLING=true
TELEGRAM_ENABLE_WEBHOOK=false
TELEGRAM_WEBHOOK_URL=

# ----------------------------------------------------------------------------
# Claude bridge (Telegram /ask routing)
# ----------------------------------------------------------------------------
CLAUDE_CONTROL_MODE=local
CLAUDE_COMMAND_TIMEOUT_SECONDS=120

# ----------------------------------------------------------------------------
# Manual-position policy
# ----------------------------------------------------------------------------
ALLOW_MANUAL_POSITION_MANAGEMENT=true
ALLOW_AUTO_CLOSE_MANUAL_POSITIONS=false

# ----------------------------------------------------------------------------
# Confirmation policy
# ----------------------------------------------------------------------------
# When true, every live order requires Telegram approval first.
REQUIRE_TELEGRAM_CONFIRMATION_FOR_LIVE_ORDER=false

# ----------------------------------------------------------------------------
# Watcher / exit-engine flags
# ----------------------------------------------------------------------------
# Trailing-stop on the watcher is OPT-IN. Disabled by default in every mode
# until the cancel-and-replace path against /fapi/v1/algoOrder has been
# validated end-to-end on a small live test position. When false (default),
# the watcher never emits TRAIL_STOP decisions for open positions.
#
# In live modes (SEMI_AUTO_LIVE / FULL_AUTO_LIVE) the watcher will, even when
# this flag is true, refuse to move the LOCAL stop_loss unless a live
# executor is wired in AND a cancel-and-replace of the exchange SL algoOrder
# succeeds atomically. See memory/execution-errors.md ERROR-20260511-4 for
# the rationale (the 2026-05-11 BUSDT incident).
EXIT_TRAILING_STOP_ENABLED=false
